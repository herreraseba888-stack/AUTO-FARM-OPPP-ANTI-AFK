-- RGB Cycle con tono rojo hacker
local function rgbCycle(obj)
	task.spawn(function()
		local hue = 0
		while obj and obj.Parent do
			hue = (hue + 3) % 360
			local color = Color3.fromHSV(hue/360, 0.95, 1)
			if obj:IsA("UIStroke") then
				obj.Color = color
			elseif obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox") then
				obj.TextColor3 = color
			end
			task.wait(0.035)
		end
	end)
end

